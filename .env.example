# =============================================================================
# VENDINHAS BACKEND - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e configure os valores
# Para gerar secrets: openssl rand -hex 32
# =============================================================================

# ===========================================
# SERVIDOR
# ===========================================
NODE_ENV=development                    # development | production | test
PORT=3001                               # Porta do servidor NestJS
CORS_ORIGIN=http://localhost:3000       # URL do frontend (produção: https://vendinhas.app)

# ===========================================
# BANCO DE DADOS (PostgreSQL)
# ===========================================
# Connection string do Prisma
DATABASE_URL="postgresql://vendapp_user:sua_senha@localhost:5432/vendapp_db"

# Configurações individuais (usadas pelo Docker Compose)
POSTGRES_USER=vendapp_user
POSTGRES_PASSWORD=sua_senha_segura      # Gere com: openssl rand -base64 24
POSTGRES_DB=vendapp_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===========================================
# JWT (Autenticação)
# ===========================================
# Diretório das chaves RSA (RS256). Se não existirem, usa HS256 com JWT_SECRET
# Gerar chaves: openssl genrsa -out keys/private.pem 2048 && openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_KEYS_DIR=./keys
JWT_SECRET=gere_com_openssl_rand_hex_32           # Fallback para HS256
JWT_REFRESH_SECRET=gere_com_openssl_rand_hex_32   # Secret do refresh token
JWT_ACCESS_TOKEN_EXPIRES_IN=1d                     # Expiração do access token
JWT_REFRESH_TOKEN_EXPIRES_IN=7d                    # Expiração do refresh token

# ===========================================
# REDIS (Cache e Blacklist de Tokens)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                         # Deixe vazio se não usar autenticação
REDIS_DB=0
REDIS_DEFAULT_TTL=3600                  # TTL padrão em segundos
REDIS_KEY_PREFIX=vendinhas:             # Prefixo das chaves no Redis

# ===========================================
# URLs DA APLICAÇÃO
# ===========================================
APP_URL=http://localhost:3001           # URL da API (produção: https://api.vendinhas.app)
FRONTEND_URL=http://localhost:3000      # URL do frontend (produção: https://vendinhas.app)
CORS_ORIGIN=http://localhost:3000       # Origem permitida em CORS (produção: https://vendinhas.app)
COOKIE_DOMAIN=                          # Vazio em dev. Em produção: .vendinhas.app (compartilha cookies entre vendinhas.app e api.vendinhas.app)

# ===========================================
# EMAIL (SMTP)
# ===========================================
# Para desenvolvimento: deixe em branco (emails serão logados no console)
# Para produção com Postfix local:
#   SMTP_HOST=localhost
#   SMTP_PORT=25
#   SMTP_USER= (vazio)
#   SMTP_PASS= (vazio)
# Para serviços externos (SendGrid, Mailgun, etc):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=sua_api_key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vendinhas.app         # Email remetente

# ===========================================
# UPLOAD DE ARQUIVOS
# ===========================================
UPLOAD_MAX_SIZE=5242880                 # Tamanho máximo em bytes (5MB)

# Storage backend for uploaded images.
#   local → grava em disco (UPLOAD_DIR) — DEV/testes apenas. NÃO persiste em
#           ambiente Dockerizado/efêmero nem com múltiplas instâncias.
#   s3    → armazena em object storage compatível com S3 (AWS S3, MinIO, R2) —
#           use em PRODUÇÃO para que avatares e imagens de produtos persistam.
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads                    # Usado apenas quando STORAGE_DRIVER=local

# Configuração S3 (obrigatória quando STORAGE_DRIVER=s3)
STORAGE_S3_BUCKET=vendinhas-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=                # vazio → usa a cadeia padrão de credenciais (IAM role)
STORAGE_S3_SECRET_ACCESS_KEY=
# Apenas para provedores não-AWS (MinIO/R2). Deixe vazio para AWS S3.
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=false        # true para MinIO/R2
# URL pública de onde os objetos são servidos (CDN ou endpoint público do bucket).
# Vazio → derivada de region/endpoint + bucket.
STORAGE_S3_PUBLIC_URL=

# --- MinIO self-hospedado (serviço do docker-compose) ---
# ROOT: administração/bootstrap apenas (minio-init cria bucket + conta de serviço).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=                     # OBRIGATÓRIO — defina uma senha forte
# APP: conta de serviço com permissão restrita ao bucket — a aplicação usa ESTA.
MINIO_APP_ACCESS_KEY=vendinhas_app
MINIO_APP_SECRET_KEY=                    # OBRIGATÓRIO — defina um segredo forte
MINIO_PORT=9000                          # Porta da API S3
MINIO_CONSOLE_PORT=9001                  # Porta do console web
# Versões fixadas das imagens (sobrescreva para atualizar deliberadamente):
# MINIO_VERSION=RELEASE.2024-10-13T13-34-11Z
# MC_VERSION=RELEASE.2024-10-08T09-37-26Z
#
# Para usar o MinIO acima, configure o driver S3 assim.
# ATENÇÃO: o backend carrega o .env via loadEnvFile() do Node, que NÃO expande
# ${VAR}. Use valores literais aqui (a sintaxe ${...} só funciona no docker-compose).
#   STORAGE_DRIVER=s3
#   STORAGE_S3_BUCKET=vendinhas-uploads          # = bucket criado pelo minio-init
#   STORAGE_S3_ACCESS_KEY_ID=vendinhas_app       # = MINIO_APP_ACCESS_KEY (não o root!)
#   STORAGE_S3_SECRET_ACCESS_KEY=troque-o-segredo # = MINIO_APP_SECRET_KEY (literal)
#   STORAGE_S3_ENDPOINT=http://localhost:9000    # backend no host falando com o MinIO
#   STORAGE_S3_FORCE_PATH_STYLE=true
#   # products/ é público; profiles/ (avatares) é privado e servido por /auth/profile/avatar.
#   STORAGE_S3_PUBLIC_URL=http://localhost:9000/vendinhas-uploads

# nodemailer + Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=seu_usuario_brevo
SMTP_PASSWORD=sua_senha_brevo
SMTP_FROM=noreply@vendinhas.app


# ===========================================
# STRIPE (Pagamentos)
# ===========================================
# Obtenha as chaves em: https://dashboard.stripe.com/apikeys
# Para testar webhooks localmente: stripe listen --forward-to localhost:3001/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_xxx           # Chave secreta (produção: sk_live_xxx)
STRIPE_WEBHOOK_SECRET=whsec_xxx         # Secret do webhook (gerado no Stripe Dashboard ou pelo CLI)
STRIPE_PRICE_PRO=price_xxx              # ID do preço do plano Pro (criado no Stripe Dashboard)
STRIPE_PRICE_ENTERPRISE=price_xxx       # ID do preço do plano Enterprise (criado no Stripe Dashboard)

# ===========================================
# PAGSEGURO (Pagamentos) - Alternativa ao Stripe
# ===========================================
# PAGSEGURO_EMAIL=seu_email@pagseguro.com
# PAGSEGURO_TOKEN=seu_token
# PAGSEGURO_WEBHOOK_SECRET=seu_webhook_secret
# PAGSEGURO_SANDBOX=true                # true para sandbox, false para produção

# ===========================================
# RATE LIMITING (Proteção contra força bruta)
# ===========================================
# RATE_LIMIT_TTL=60                     # Janela de tempo em segundos
# RATE_LIMIT_MAX=100                    # Máximo de requisições por janela

# ===========================================
# ARGON2 (Hash de senhas)
# ===========================================
# ARGON2_MEMORY_COST=65536              # Custo de memória em KiB (padrão: 64MB)
# ARGON2_TIME_COST=3                    # Iterações (padrão: 3)
# ARGON2_PARALLELISM=4                  # Threads paralelas (padrão: 4)

# ===========================================
# OAUTH (Login Social)
# ===========================================
# Google — console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs:
#   dev:  http://localhost:3001/auth/google/callback
#   prod: https://api.vendinhas.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Facebook — developers.facebook.com → My Apps → Facebook Login → Settings
# Valid OAuth Redirect URIs:
#   dev:  http://localhost:3001/auth/facebook/callback
#   prod: https://api.vendinhas.app/auth/facebook/callback
# App Domain (prod): vendinhas.app
# Privacy Policy URL: https://vendinhas.app/privacy
# Terms of Service URL: https://vendinhas.app/terms
# Data Deletion Instructions URL: https://vendinhas.app/data-deletion
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/facebook/callback